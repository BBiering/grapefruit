# EODHD API key — powers the universe, daily bars, company metadata, and news.
# Get one at https://eodhd.com/
EODHD_API_KEY=
# Perplexity API key for AI catalyst explanations on the ticker detail page.
# Get one at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# Supabase Postgres connection string. Use the "Session pooler" URI from
# Supabase → Settings → Database → Connection string → Session pooler.
# Do NOT use "Direct connection" — it's IPv6-only and most hosts (Render
# free tier included) can't reach it. Session mode (port 5432) works with
# psycopg's connection pool.
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Comma-separated allowed CORS origins for the deployed frontend. Local dev
# (http://localhost:5173) is always allowed regardless of this value.
FRONTEND_ORIGIN=https://grapefruit.vercel.app
