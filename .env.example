# Backend / Cloud Run Job secrets (set in GCP, NOT pushed to git).
# Use this file as a local-dev convenience: `cp .env.example .env` then fill in.

# EODHD API key — powers universe, bars, fundamentals, news, earnings calendar.
EODHD_API_KEY=
# Perplexity API key for catalyst explanations (winners enrichment).
PERPLEXITY_API_KEY=
# Supabase Postgres: use the Session pooler URI (port 5432). NOT "Direct
# connection" (IPv6-only).
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Frontend (Vercel). Public values; the anon key is RLS-restricted to SELECT.
# Both must be set in the Vercel project, NOT in this .env (Vite reads them
# at build time on Vercel itself).
# VITE_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
