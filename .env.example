# EODHD API key — powers the universe, daily bars, company metadata, and news.
# Get one at https://eodhd.com/
EODHD_API_KEY=
# Perplexity API key for AI catalyst explanations on the ticker detail page.
# Get one at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# Supabase Postgres connection string. Grab the "Direct connection" URI from
# Supabase → Settings → Database. Required.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Comma-separated allowed CORS origins for the deployed frontend. Local dev
# (http://localhost:5173) is always allowed regardless of this value.
FRONTEND_ORIGIN=https://grapefruit.vercel.app
